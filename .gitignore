# Obsidian workspace (changes every time you open a note — noisy)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Nested obsidian config (never should exist)
.obsidian/.obsidian/

# Plugin binaries (large, reinstall from Obsidian)
.obsidian/plugins/*/main.js
.obsidian/plugins/*/styles.css

# OS junk
.DS_Store
Thumbs.db
desktop.ini
